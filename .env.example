# Claude API Key —— Anthropic 官方或兼容 Anthropic 协议的网关
# 本地开发：复制本文件为 .env.local 并填入真实值；切勿提交真实 Key
ANTHROPIC_API_KEY=your-claude-api-key-here

# 可选：自定义网关地址(Anthropic 原生协议)。用 Anthropic 官方则留空
ANTHROPIC_BASE_URL=https://your-gateway-url

# 可选：指定 Claude 模型，默认 claude-sonnet-4-6
ANTHROPIC_MODEL=claude-sonnet-4-6
